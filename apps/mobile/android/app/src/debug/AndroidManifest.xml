<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Dev only: the local API is served over http (http://10.0.2.2:3000).
         Android 9+ blocks cleartext by default, so allow it in debug builds
         only. Release builds inherit the main manifest (cleartext stays off),
         so production must use HTTPS. -->
    <application android:usesCleartextTraffic="true"/>
</manifest>
