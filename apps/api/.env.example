NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://afristage:afristage@localhost:5432/afristage?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Paystack signs webhooks with HMAC-SHA512 of the raw body using this secret key.
# Handles African-currency card checkouts (NGN/GHS/KES/ZAR).
PAYSTACK_SECRET_KEY=replace_me
FLUTTERWAVE_SECRET_KEY=replace_me
FLUTTERWAVE_WEBHOOK_SECRET=replace_me
# Stripe handles non-African-currency card checkouts (USD today). Leave unset to
# keep Stripe disabled — the provider self-guards until STRIPE_SECRET_KEY is set.
# Use a RESTRICTED key (Checkout Sessions read/write only), never the full secret.
STRIPE_SECRET_KEY=replace_me
# From the Stripe dashboard webhook pointed at POST /payments/webhooks/stripe,
# subscribed to checkout.session.completed. Signs t=/v1= HMAC-SHA256.
STRIPE_WEBHOOK_SECRET=replace_me
# Optional: where the browser lands after checkout, and the replay window (sec).
STRIPE_SUCCESS_URL=https://afristage.live/wallet?paid=1
STRIPE_CANCEL_URL=https://afristage.live/wallet?canceled=1
STRIPE_WEBHOOK_TOLERANCE_SEC=300
PLATFORM_CURRENCY=COIN
CREATOR_SHARE_BPS=6000
# Payout: coins are the withdrawal unit; minimum withdrawal in coins.
MIN_PAYOUT_COIN=500
# Explicit coin -> fiat settlement conversion (fiat minor units per coin) + currency.
COIN_TO_FIAT_MINOR_RATE=100
CREATOR_PAYOUT_CURRENCY=NGN
# Mock payment completion is blocked in production unless this is exactly "true".
# ENABLE_MOCK_PAYMENTS=false
# LIVE rooms idle (no start/chat/gift) longer than this are auto-ended (cron every 5 min).
ROOM_STALE_MINUTES=30
# Set true to force privileged (admin/moderator/payout) accounts to set up MFA before login.
# REQUIRE_ADMIN_MFA=false
# Per-user chat rate limit: max messages per window (in-memory; use Redis for multi-instance).
CHAT_RATE_LIMIT=5
CHAT_RATE_WINDOW_MS=5000
# Payout fraud hold: a creator younger than N days requesting >= this many coins is HELD for review.
FRAUD_NEW_CREATOR_DAYS=14
FRAUD_LARGE_PAYOUT_COIN=1000000
# Set THROTTLE_DISABLED=true ONLY for test/CI runs (functional validation scripts). Never in prod.
# THROTTLE_DISABLED=false
# Object storage for user uploads (avatars, gift animations). Files go to S3-compatible
# storage via presigned PUT; the DB only stores the resulting CDN URL. Local dev uses the
# MinIO service in docker-compose. CDN_BASE_URL is the public base prepended to object keys.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=afristage-media
S3_ACCESS_KEY_ID=afristage
S3_SECRET_ACCESS_KEY=afristage123
S3_FORCE_PATH_STYLE=true
CDN_BASE_URL=http://localhost:9000/afristage-media
